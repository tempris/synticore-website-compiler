{
  "name": "synticore-website-compiler",
  "version": "1.1.4",
  "description": "Synticore Website Compiler - modular Gulp build pipeline for HTML, SCSS, JS, and assets",
  "author": "Cure Interactive <main@cureinteractive.com> (https://cureinteractive.com)",
  "homepage": "https://synticore.cureinteractive.com",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cureinteractive/synticore-website-compiler"
  },
  "bugs": {
    "url": "https://github.com/cureinteractive/synticore-website-compiler/issues"
  },
  "keywords": [
    "synticore",
    "gulp",
    "build",
    "scss",
    "html",
    "handlebars",
    "static-site-generator",
    "modular-pipeline",
    "gulpfile"
  ],
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "browserify": {
    "transform": [
      "browserify-shim"
    ]
  },
  "browser": {
    "jquery": "./node_modules/jquery/dist/jquery.js"
  },
  "browserify-shim": {
    "jquery": "$"
  },
  "scripts": {
    "gulp": "node ./node_modules/gulp-cli/bin/gulp.js",
    "gui:web": "node ./source/script/gui_browser.js",
    "project:new": "node ./source/script/project_new.js"
  },
  "devDependencies": {
    "@babel/core": "7.26.0",
    "@babel/preset-env": "7.26.0",
